# Required for address geocoding and true radius-based local facility collection.
KAKAO_REST_API_KEY=

# Required for Korean news and policy search collection.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional. Enables LLM commentary on top of the rule-based report.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional. Set if your OpenAI organization uses regional endpoints.
# OPENAI_BASE_URL=https://kr.api.openai.com/v1

# Optional but strongly recommended. Enables real MOLIT apartment-trade
# (실거래가) and 전월세(전세가율) data instead of relying only on keyword-based
# news/policy signals for the score. Issue a key at:
# https://www.data.go.kr/data/15058747/openapi.do (국토교통부_아파트매매 실거래자료)
# Apply for the rent one too under the same account (same key, no separate
# env var needed): https://www.data.go.kr/data/15126474/openapi.do
MOLIT_API_KEY=

# Optional. Adds the current Bank of Korea base rate (기준금리) as macro
# context (does not affect the score). Register at https://ecos.bok.or.kr/api/
ECOS_API_KEY=
